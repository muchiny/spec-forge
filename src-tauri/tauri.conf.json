{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Spec Forge",
  "version": "0.1.0",
  "identifier": "dev.muchini.spec-forge",
  "build": {
    "beforeBuildCommand": "cd ../ui && npm run build",
    "beforeDevCommand": "cd ../ui && npm run dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Spec Forge",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "maximizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-eval'; img-src 'self' asset: https://asset.localhost data:; connect-src ipc: http://ipc.localhost http://localhost:1420 ws://localhost:1420",
      "freezePrototype": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.ico"],
    "shortDescription": "Transforme des User Stories en Specifications ISO 29148 et Tests Gherkin/BDD",
    "license": "MIT",
    "publisher": "muchini",
    "category": "DeveloperTool"
  }
}
